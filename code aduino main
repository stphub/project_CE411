// TASK 1: SENSORS (Core 1)
// ==========================================
void SensorTask(void* pvParameters) {

  // --- Heart Rate ---
  int   baseline       = 2048;
  int   smoothed       = 2048;
  int   peakVal        = 0;
  int   valleyVal      = 0;
  bool  risingEdge     = false;
  unsigned long lastBeatTime    = 0;
  unsigned long risingEdgeStart = 0;
  float ibiList[IBI_BUFFER_SIZE];
  for (int i = 0; i < IBI_BUFFER_SIZE; i++) ibiList[i] = 800.0f;
  int ibiIndex      = 0;
  int ibiLocalCount = 0;

  // --- Step ---
  bool          valleyDetected = false;
  unsigned long lastStepTime   = 0;

  // --- Wrist ---
  bool isWristUp = false;

  // --- SOS ---
  unsigned long sosPresStart        = 0;
  bool          buttonCancelledFall = false;

  // --- Fall ---
  int           impactSamples  = 0;
  bool          impactDetected = false;
  unsigned long impactTime     = 0;
  bool          wentStillOnce  = false;

  for (;;) {
    sensors_event_t a, g, temp;
    mpu.getEvent(&a, &g, &temp);

    float lx      = a.acceleration.x;
    float ly      = a.acceleration.y;
    float lz      = a.acceleration.z;
    float ltotalG = sqrtf(lx*lx + ly*ly + lz*lz);
    float pitch   = atan2f(-lx, sqrtf(ly*ly + lz*lz)) * 180.0f / PI;

    float lgx      = g.gyro.x;
    float lgy      = g.gyro.y;
    float lgz      = g.gyro.z;
    float lgyroMag = sqrtf(lgx*lgx + lgy*lgy + lgz*lgz);

    // ----- Motion Engine -----
    motionWin.push(ltotalG, lgyroMag);
    ActivityState lActivity = classifyActivity();

    // ==========================================
    // Heart Rate & HRV
    // ==========================================
    int rawPulse = analogRead(HEART_RATE_PIN);

    smoothed = ((10 - HR_LPF_ALPHA) * smoothed + HR_LPF_ALPHA * rawPulse) / 10;
    baseline = ((100 - HR_ADAPTIVE_ALPHA) * baseline + HR_ADAPTIVE_ALPHA * smoothed) / 100;

    int signal = smoothed - baseline;

    int adaptiveThreshold = (int)((float)(peakVal - valleyVal) * HR_PEAK_RATIO);
    adaptiveThreshold = max(adaptiveThreshold, HR_MIN_THRESHOLD);

    // แก้: decay แบบ ratio แทน -1 ป้องกัน peakVal หายเร็วเกิน
    if (peakVal   > 0) peakVal   = (int)(peakVal   * 0.99f);
    if (valleyVal < 0) valleyVal = (int)(valleyVal  * 0.99f);

    if (signal > peakVal)   peakVal   = signal;
    if (signal < valleyVal) valleyVal = signal;

    if (!risingEdge && signal > adaptiveThreshold) {
      risingEdge      = true;
      risingEdgeStart = millis();
    }
    if (risingEdge && millis() - risingEdgeStart > HR_PEAK_TIMEOUT_MS) {
      risingEdge = false;
    }

    if (risingEdge && signal < adaptiveThreshold * 0.6f) {
      risingEdge = false;

      unsigned long now = millis();
      unsigned long ibi = now - lastBeatTime;

      // แก้: refractory filter — ข้าม IBI ที่ผิดปกติ ไม่ reset lastBeatTime
      if (ibi < IBI_MIN_MS || ibi > IBI_MAX_MS) {
        lastBeatTime = now;
      } else {
        int instantBPM = (int)(60000UL / ibi);

        if (instantBPM >= HR_MIN_BPM && instantBPM <= HR_MAX_BPM) {
          ibiList[ibiIndex] = (float)ibi;
          ibiIndex = (ibiIndex + 1) % IBI_BUFFER_SIZE;
          if (ibiLocalCount < IBI_BUFFER_SIZE) ibiLocalCount++;

          bool ready = (ibiLocalCount >= IBI_BUFFER_SIZE);

          LOCK();
          shared.ibiFilledCount = ibiLocalCount;
          shared.ibiReady       = ready;
          UNLOCK();

          if (ready) {
            int   validN = min(ibiLocalCount, IBI_BUFFER_SIZE);
            float avgIBI = 0.0f;
            for (int i = 0; i < validN; i++) avgIBI += ibiList[i];
            avgIBI /= (float)validN;

            float sumDiffSq = 0.0f;
            for (int i = 0; i < validN; i++) {
              float d = ibiList[i] - avgIBI;
              sumDiffSq += d * d;
            }
            float sdnn   = sqrtf(sumDiffSq / (float)validN);
            int   stress = (sdnn >= 50.0f) ? 1 : (sdnn >= 35.0f) ? 2 : (sdnn >= 20.0f) ? 3 : 4;

            LOCK();
            shared.bpm         = (int)(60000.0f / avgIBI);
            shared.hrvSDNN     = sdnn;
            shared.stressLevel = stress;
            UNLOCK();
          }
        }
        lastBeatTime = now;
      }
    }

    // แก้: Debug HR ปิด/เปิดด้วย #define DEBUG_HR
#ifdef DEBUG_HR
    static unsigned long lastHRDebug = 0;
    if (millis() - lastHRDebug >= 20) {
      lastHRDebug = millis();
      Serial.print("raw:");      Serial.print(rawPulse);
      Serial.print("\tsmooth:"); Serial.print(smoothed);
      Serial.print("\tsignal:"); Serial.print(signal);
      Serial.print("\tthresh:"); Serial.print(adaptiveThreshold);
      Serial.print("\tbpm:");    Serial.println(shared.bpm);
    }
#endif

    // ----- Step & Exercise -----
    if (ltotalG < STEP_VALLEY_G) valleyDetected = true;
    if (ltotalG > STEP_PEAK_G && valleyDetected &&
        (millis() - lastStepTime > STEP_DEBOUNCE_MS)) {
      lastStepTime   = millis();
      valleyDetected = false;
      LOCK(); shared.stepCount++; UNLOCK();
    }
    if (pitch > WRIST_UP_PITCH  && !isWristUp) isWristUp = true;
    if (pitch < WRIST_DOWN_PITCH && isWristUp) {
      isWristUp = false;
      LOCK(); shared.exerciseCount++; UNLOCK();
    }

    // ----- Fall Detection -----
    buttonCancelledFall = false;
    handleFallDetection(
      ltotalG, lgyroMag,
      impactSamples, impactDetected,
      impactTime, wentStillOnce,
      buttonCancelledFall, sosPresStart
    );

    // ----- SOS Button -----
    if (!buttonCancelledFall) {
      bool btnPressed = (digitalRead(SOS_BUTTON_PIN) == LOW);
      if (btnPressed) {
        if (sosPresStart == 0) sosPresStart = millis();
      if (millis() - sosPresStart > 3000) {
          LOCK();
          shared.isSOS = true;
          shared.sosCount++;
          int idx = min(shared.sosCount - 1, MAX_SOS_LOG - 1);
          struct tm t;
          if (getLocalTime(&t)) {
            strftime(shared.sosTimes[idx], 10, "%H:%M", &t);
          }
          UNLOCK();
          sosPresStart = 0;
          queueAlert("🆘 SOS! ผู้สวมใส่ต้องการความช่วยเหลือ");
          for (int i = 0; i < 3; i++) {
            digitalWrite(BUZZER_PIN, HIGH); vTaskDelay(pdMS_TO_TICKS(80));
            digitalWrite(BUZZER_PIN, LOW);  vTaskDelay(pdMS_TO_TICKS(80));
          }
        }
      } else {
        sosPresStart = 0;
      }
    }

    // ----- อัปเดต shared -----
    LOCK();
    shared.x        = lx;
    shared.y        = ly;
    shared.z        = lz;
    shared.totalG   = ltotalG;
    shared.gyroMag  = lgyroMag;
    shared.activity = lActivity;
    UNLOCK();

    vTaskDelay(pdMS_TO_TICKS(10));
  }
}

