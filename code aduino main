struct MotionWindow {
  float gBuf[ME_WINDOW];
  float gyroBuf[ME_WINDOW];
  int   head;
  int   count;

  void push(float g, float gyro) {
    gBuf[head]    = g;
    gyroBuf[head] = gyro;
    head = (head + 1) % ME_WINDOW;
    if (count < ME_WINDOW) count++;
  }

  void stats(float& outVarG, float& outAvgGyro) {
    if (count == 0) { outVarG = outAvgGyro = 0.0f; return; }
    float sumG = 0.0f, sumGyro = 0.0f;
    for (int i = 0; i < count; i++) { sumG += gBuf[i]; sumGyro += gyroBuf[i]; }
    float avgG = sumG / count;
    outAvgGyro  = sumGyro / count;
    float sumSq = 0.0f;
    for (int i = 0; i < count; i++) { float d = gBuf[i] - avgG; sumSq += d * d; }
    outVarG = sumSq / count;
  }
} motionWin = {};

ActivityState classifyActivity() {
  if (motionWin.count < ME_WARMUP_SAMPLES) return ACT_STILL;
  float varG, avgGyro;
  motionWin.stats(varG, avgGyro);
  if (varG <= ME_VAR_STILL_MAX  && avgGyro <= ME_GYRO_STILL)  return ACT_STILL;
  if (varG <= ME_VAR_MOVING_MAX && avgGyro <= ME_GYRO_MOVING) return ACT_MOVING;
  if (varG <= ME_VAR_WALKING_MAX)                               return ACT_WALKING;
  return ACT_RUNNING;
}

