  msg += "การล้ม: " + String(snap.fallCount) + " ครั้ง\n";
  for (int i = 0; i < min(snap.fallCount, MAX_FALL_LOG); i++) {
    msg += "  ครั้งที่ " + String(i+1) + ": " + String(snap.fallTimes[i]) + "\n";
  }

  msg += "กดขอความช่วยเหลือ: " + String(snap.sosCount) + " ครั้ง\n";
    for (int i = 0; i < min(snap.sosCount, MAX_SOS_LOG); i++) {
    msg += "  ครั้งที่ " + String(i+1) + ": " + String(snap.sosTimes[i]) + "\n";
  }
  msg += "กิจกรรมล่าสุด: " + String(activityLabel[snap.activity]) + "\n";
  msg += "คะแนนสุขภาพ: " + String(snap.healthScore) + "/100";
  return msg;
}
void CloudTask(void* pvParameters) {
  int lastSavedDay = -1;
  int lastDailyReportDay = -1; 

  unsigned long wifiBackoff   = WIFI_RECONNECT_BASE_MS;
  unsigned long lastReconnect = 0;

  for (;;) {
    // แก้: disconnect ก่อน reconnect — ป้องกัน stuck
    if (WiFi.status() != WL_CONNECTED) {
      unsigned long now = millis();
      if (now - lastReconnect >= wifiBackoff) {
        Serial.println("[WiFi] Reconnecting...");
        WiFi.disconnect();
        WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
        lastReconnect = now;
        wifiBackoff   = min(wifiBackoff * 2, WIFI_RECONNECT_MAX_MS);
      }
      vTaskDelay(pdMS_TO_TICKS(500));
      continue;
    }
    wifiBackoff = WIFI_RECONNECT_BASE_MS;

    // drain alert queue
    char alertBuf[ALERT_MSG_MAX];
    while (xQueueReceive(alertQueue, alertBuf, 0) == pdTRUE) {
      sendTelegramAlert(String(alertBuf));
    }

    if (!Firebase.ready()) { vTaskDelay(pdMS_TO_TICKS(1000)); continue; }

    LOCK();
    SharedData snap = shared;
    UNLOCK();

    int score = map(constrain(snap.stepCount, 0, HEALTH_STEP_MAX),
                    0, HEALTH_STEP_MAX, HEALTH_SCORE_BASE, HEALTH_SCORE_MAX);
    if (snap.stressLevel >= STRESS_PENALTY_LVL) score -= STRESS_SCORE_PENALTY;
    if (snap.activity == ACT_RUNNING)      score = min(score + 5, HEALTH_SCORE_MAX);
    else if (snap.activity == ACT_WALKING) score = min(score + 2, HEALTH_SCORE_MAX);
    score = constrain(score, 0, HEALTH_SCORE_MAX);
    LOCK(); shared.healthScore = score;  UNLOCK();
    snap.healthScore = score;

    FirebaseJson json;
    json.set("x",             snap.x);
    json.set("y",             snap.y);
    json.set("z",             snap.z);
    json.set("total_g",       snap.totalG);
    json.set("gyroMag",       snap.gyroMag);
    json.set("heartRate",     snap.bpm);
    json.set("hrvSDNN",       snap.hrvSDNN);
    json.set("stressLevel",   snap.stressLevel);
    json.set("ibiReady",      snap.ibiReady);
    json.set("isFallen",      snap.isFallen);
    json.set("isSOS",         snap.isSOS);
    json.set("stepCount",     snap.stepCount);
    json.set("exerciseCount", snap.exerciseCount);
    json.set("healthScore",   snap.healthScore);
    json.set("fallPhase",     String(snap.fallPhase));
    json.set("fallCountdown", snap.fallCountdown);
    json.set("activity",      String(activityLabel[snap.activity]));
    json.set("fallCount",     snap.fallCount);   // ← เพิ่ม
json.set("sosCount",      snap.sosCount);    // ← เพิ่ม

    // แก้: log เมื่อ Firebase write ล้มเหลว
    if (!Firebase.RTDB.setJSON(&fbdo, "/SmartGlove/Live", &json)) {
      Serial.printf("[Firebase Error] %s\n", fbdo.errorReason().c_str());
    }

   struct tm timeinfo;
    if (getLocalTime(&timeinfo)) {

      // --- init วันแรก ---
      if (lastSavedDay == -1) {
        lastSavedDay = timeinfo.tm_mday;
      }

      // --- บันทึก history เมื่อวันเปลี่ยน ---
      else if (timeinfo.tm_mday != lastSavedDay) {
        char dateStr[20];
        strftime(dateStr, sizeof(dateStr), "%Y-%m-%d", &timeinfo);
        FirebaseJson history;
        history.set("healthScore",   snap.healthScore);
        history.set("stepCount",     snap.stepCount);
        history.set("exerciseCount", snap.exerciseCount);
        history.set("lastActivity",  String(activityLabel[snap.activity]));
        if (!Firebase.RTDB.setJSON(&fbdo,
              ("/SmartGlove/History/" + String(dateStr)).c_str(), &history)) {
          Serial.printf("[Firebase History Error] %s\n", fbdo.errorReason().c_str());
        }
            LOCK(); 
        shared.stepCount     = 0; 
        shared.exerciseCount = 0;
        shared.fallCount     = 0;
        shared.sosCount      = 0;
        UNLOCK();
        lastSavedDay = timeinfo.tm_mday;
      }

      // --- ส่งรายงานหลังเที่ยงคืน ---
      bool isMidnight = (timeinfo.tm_hour == 0 && timeinfo.tm_min == 0);
      if (isMidnight && lastDailyReportDay != timeinfo.tm_mday) {
        lastDailyReportDay = timeinfo.tm_mday;
        time_t yesterday = mktime(&timeinfo) - 86400;
        struct tm* ytm = localtime(&yesterday);
        char dateStr[20];
        strftime(dateStr, sizeof(dateStr), "%Y-%m-%d", ytm);
        LOCK();
        SharedData reportSnap = shared;
        UNLOCK();
        String summary = buildDailySummary(reportSnap, dateStr);
        queueAlert(summary.c_str());
        Serial.println("[Daily Report] Queued");
      }

    } // ปิด getLocalTime

    // แก้: getBool แยก check ก่อน boolData()
    if (Firebase.RTDB.getBool(&fbdo, "/SmartGlove/Control/resetSOS")) {
      if (fbdo.boolData()) {
        LOCK(); shared.isSOS = false; UNLOCK();
        Firebase.RTDB.setBool(&fbdo, "/SmartGlove/Control/resetSOS", false);
      }
    }
    if (Firebase.RTDB.getBool(&fbdo, "/SmartGlove/Control/resetFall")) {
      if (fbdo.boolData()) {
        LOCK();
        shared.isFallen      = false;
        shared.fallCountdown = 0;
        shared.currentFall   = FALL_NONE;
        SAFE_STRCPY(shared.fallPhase, "none");
        UNLOCK();
        Firebase.RTDB.setBool(&fbdo, "/SmartGlove/Control/resetFall", false);
      }
    }
    if (Firebase.RTDB.getBool(&fbdo, "/SmartGlove/Control/findMe")) {
      if (fbdo.boolData()) {
        for (int i = 0; i < 5; i++) {
          digitalWrite(BUZZER_PIN, HIGH); vTaskDelay(pdMS_TO_TICKS(100));
          digitalWrite(BUZZER_PIN, LOW);  vTaskDelay(pdMS_TO_TICKS(100));
        }
        Firebase.RTDB.setBool(&fbdo, "/SmartGlove/Control/findMe", false);
      }
    }
       if (Firebase.RTDB.getBool(&fbdo, "/SmartGlove/Control/testReport")) {
      if (fbdo.boolData()) {
        LOCK();
        SharedData reportSnap = shared;
        UNLOCK();
         struct tm testTime;          // ← ดึงเวลาใหม่ตรงนี้เลย
        char dateStr[20];
        if (getLocalTime(&testTime)) {
          strftime(dateStr, sizeof(dateStr), "%Y-%m-%d", &testTime);
        } else {
          strcpy(dateStr, "TEST-DATE");
        }
        String summary = buildDailySummary(reportSnap, dateStr);
        queueAlert(summary.c_str());
        Serial.println("[Test] Manual report sent");
        Firebase.RTDB.setBool(&fbdo, "/SmartGlove/Control/testReport", false);
      }
    }
    

    vTaskDelay(pdMS_TO_TICKS(1000));
  }
}

// ==========================================
// setup & loop
// ==========================================
void setup() {
  Serial.begin(115200);
  pinMode(BUZZER_PIN,     OUTPUT);
  pinMode(SOS_BUTTON_PIN, INPUT_PULLUP);
  Wire.begin();

  analogSetAttenuation(ADC_11db);
  analogReadResolution(12);
  analogSetPinAttenuation(HEART_RATE_PIN, ADC_11db);

  if (!mpu.begin()) {
    Serial.println("[Error] MPU6050 ไม่พบ — ตรวจสอบสาย");
    while (1) vTaskDelay(pdMS_TO_TICKS(1000));
  }

  // แก้: ตั้งค่า MPU6050 ให้เหมาะกับ glove
  mpu.setAccelerometerRange(MPU6050_RANGE_16_G);
  mpu.setGyroRange(MPU6050_RANGE_500_DEG);
  mpu.setFilterBandwidth(MPU6050_BAND_21_HZ);

  dataMutex = xSemaphoreCreateMutex();
  configASSERT(dataMutex);

  alertQueue = xQueueCreate(ALERT_QUEUE_LEN, ALERT_MSG_MAX);
  configASSERT(alertQueue);

  memset(&shared, 0, sizeof(shared));
  SAFE_STRCPY(shared.fallPhase, "none");
  shared.stressLevel    = 1;
  shared.activity       = ACT_STILL;
  shared.currentFall    = FALL_NONE;
  shared.ibiReady       = false;
  shared.ibiFilledCount = 0;

  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  while (WiFi.status() != WL_CONNECTED) delay(500);
  Serial.println("[WiFi] Connected: " + WiFi.localIP().toString());

  configTime(gmtOffset_sec, daylightOffset_sec, ntpServer);

  config.api_key      = API_KEY;
  config.database_url = DATABASE_URL;

  // แก้: log Firebase signup result
  if (Firebase.signUp(&config, &auth, "", "")) {
    Serial.println("[Firebase] Signup OK");
  } else {
    Serial.printf("[Firebase] Signup Failed: %s\n",
                  config.signer.signupError.message.c_str());
  }

  Firebase.begin(&config, &auth);
  Firebase.reconnectWiFi(true);   // แก้: ให้ Firebase auto-reconnect WiFi
  // สร้าง Control อัตโนมัติ

Firebase.RTDB.setBool(&fbdo, "/SmartGlove/Control/findMe", false);
Firebase.RTDB.setBool(&fbdo, "/SmartGlove/Control/resetSOS", false);
Firebase.RTDB.setBool(&fbdo, "/SmartGlove/Control/resetFall", false);
Firebase.RTDB.setBool(&fbdo, "/SmartGlove/Control/testReport", false);

  xTaskCreatePinnedToCore(SensorTask, "SensorTask", SENSOR_TASK_STACK, NULL, 3, &SensorTaskHandle, 1);
  xTaskCreatePinnedToCore(CloudTask,  "CloudTask",  CLOUD_TASK_STACK,  NULL, 1, &CloudTaskHandle,  0);
}

// แก้: ใช้ portMAX_DELAY แทน vTaskDelete เพื่อไม่ให้ idle task หาย
void loop() {
  vTaskDelay(portMAX_DELAY);
}
