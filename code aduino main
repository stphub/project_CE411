String urlEncode(String str) {
  String encoded = "";
  for (int i = 0; i < str.length(); i++) {
    unsigned char c = str.charAt(i);
    if (c == ' ') {
      encoded += '+';
    } else if (isAlphaNumeric(c) || c == '-' || c == '_' || c == '.' || c == '~') {
      encoded += (char)c;
    } else {
      char buf[4];
      sprintf(buf, "%%%02X", c);
      encoded += buf;
    }
  }
  return encoded;
}
void sendTelegramAlert(String msg) {
  if (WiFi.status() != WL_CONNECTED) return;
  
  // ตัดส่งทีละ 3000 ตัว (เผื่อ multi-byte)
  const int CHUNK = 3000;
  int total = msg.length();
  int sent  = 0;

  while (sent < total) {
    String chunk = msg.substring(sent, min(sent + CHUNK, total));
    
    HTTPClient http;
    String url = "https://api.telegram.org/bot" + BOT_TOKEN + "/sendMessage";
    http.begin(url);
    http.addHeader("Content-Type", "application/x-www-form-urlencoded");
    String body = "chat_id=" + CHAT_ID + "&text=" + urlEncode(chunk);
    int httpCode = http.POST(body);
    if (httpCode > 0) {
      Serial.printf("[Telegram] Sent chunk (%d)\n", httpCode);
    } else {
      Serial.printf("[Telegram] Failed: %s\n", http.errorToString(httpCode).c_str());
    }
    http.end();
    sent += CHUNK;
    if (sent < total) vTaskDelay(pdMS_TO_TICKS(500)); // หน่วงระหว่าง chunk
  }
}
// แก้: log เมื่อ queue เต็ม
void queueAlert(const char* msg) {
  char buf[ALERT_MSG_MAX];
  strncpy(buf, msg, ALERT_MSG_MAX - 1);
  buf[ALERT_MSG_MAX - 1] = '\0';
  if (xQueueSend(alertQueue, buf, 0) != pdTRUE) {
    Serial.println("[Warning] Alert queue full");
  }
}

// ==========================================
// 8. Fall Handler (ไม่มี goto)
// ==========================================
void handleFallDetection(
  float ltotalG, float lgyroMag,
  int&           impactSamples,
  bool&          impactDetected,
  unsigned long& impactTime,
  bool&          wentStillOnce,
  bool&          buttonCancelledFall,
  unsigned long& sosPresStart
) {
  LOCK();
  FallPhase     currentFall = shared.currentFall;
  unsigned long fallTrigger = shared.fallTriggerTime;
  UNLOCK();

  if (currentFall == FALL_NONE) {
    if (ltotalG > FALL_TRIGGER_G && lgyroMag > FALL_GYRO_MIN) {
      impactSamples++;
    } else {
      impactSamples = 0;
    }
    if (impactSamples >= FALL_IMPACT_MIN_SAMPLES) {
      impactSamples  = 0;
      impactDetected = true;
      impactTime     = millis();
      wentStillOnce  = false;
      LOCK();
      shared.currentFall     = FALL_PRE_ALERT;
      shared.fallTriggerTime = millis();
      UNLOCK();
    }
    return;
  }

  if (currentFall == FALL_PRE_ALERT) {
    unsigned long elapsed         = millis() - fallTrigger;
    unsigned long timeSinceImpact = millis() - impactTime;

    if (ltotalG < FALL_STILL_G_MAX) wentStillOnce = true;

    if (timeSinceImpact > FALL_POST_STILL_MS && !wentStillOnce) {
      LOCK();
      shared.currentFall   = FALL_NONE;
      shared.fallCountdown = 0;
      SAFE_STRCPY(shared.fallPhase, "none");
      UNLOCK();
      impactDetected = false;
      wentStillOnce  = false;
      impactTime     = 0;
      return;
    }

    int cd = max(0, (int)((FALL_PRE_ALERT_MS - (long)elapsed) / 1000));
    LOCK();
    shared.fallCountdown = cd;
    SAFE_STRCPY(shared.fallPhase, "pre_alert");
    UNLOCK();

    digitalWrite(BUZZER_PIN, (millis() % 200 < 100));

    if (digitalRead(SOS_BUTTON_PIN) == LOW) {
      LOCK();
      shared.currentFall   = FALL_NONE;
      shared.isFallen      = false;
      shared.fallCountdown = 0;
      SAFE_STRCPY(shared.fallPhase, "none");
      UNLOCK();
      digitalWrite(BUZZER_PIN, LOW);
      buttonCancelledFall = true;
      impactDetected      = false;
      wentStillOnce       = false;
      impactTime          = 0;
      sosPresStart        = 0;
      vTaskDelay(pdMS_TO_TICKS(500));
      return;
    }

 if (elapsed > FALL_PRE_ALERT_MS) {
      LOCK();
      shared.currentFall = FALL_CONFIRMED;
      shared.isFallen    = true;
      shared.fallCount++;
      int idx = min(shared.fallCount - 1, MAX_FALL_LOG - 1);
      struct tm t;
      if (getLocalTime(&t)) {
        strftime(shared.fallTimes[idx], 10, "%H:%M", &t);
      }               
      SAFE_STRCPY(shared.fallPhase, "confirmed");
      UNLOCK();
      digitalWrite(BUZZER_PIN, LOW);
      impactDetected = false;
      wentStillOnce  = false;
      impactTime     = 0;
      queueAlert("⚠️ ตรวจพบการล้ม! กรุณาตรวจสอบ");
    }
  }  // ← ปิด if (currentFall == FALL_PRE_ALERT)

  if (currentFall == FALL_CONFIRMED) {
    unsigned long elapsed = millis() - fallTrigger;
    if (elapsed > 5000UL) {
      LOCK();
      shared.currentFall   = FALL_NONE;
      shared.isFallen      = false;
      SAFE_STRCPY(shared.fallPhase, "none");
      UNLOCK();
    }
    return;
  }
}  // ← ปิด handleFallDetection


